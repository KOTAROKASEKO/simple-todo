{
  "manifest_version": 3,
  "name": "SimpleTodo Companion",
  "version": "1.0.0",
  "description": "Sidebar todo extension connected to Firebase.",
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "alarms"
  ]
}