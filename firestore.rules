rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Client must not add or change server-only field (merge updates must not be rejected when doc already has it).
    function noServerReminderFieldsOnCreate() {
      return !('reminderLastSentAt' in request.resource.data);
    }
    function noServerReminderFieldsOnUpdate() {
      return !('reminderLastSentAt' in request.resource.data)
        || (('reminderLastSentAt' in resource.data) && request.resource.data.reminderLastSentAt == resource.data.reminderLastSentAt);
    }

    function validJournalAiCharacter(v) {
      return v == 'default'
        || v == 'gyaru'
        || v == 'kopitiam_uncle'
        || v == 'chinese_auntie';
    }

    function validTaskCoins(v) {
      return v is int && v >= 0 && v <= 2000000;
    }

    function validUnlockedCharactersList(lst) {
      return lst is list && lst.size() <= 8;
    }

    function validJournalDailyReminderOffset(v) {
      return v is int && v >= -840 && v <= 840;
    }

    function journalReminderServerKeyOk() {
      return !('journalDailyReminderLastSentDayKey' in request.resource.data)
        || (('journalDailyReminderLastSentDayKey' in resource.data)
            && request.resource.data.journalDailyReminderLastSentDayKey == resource.data.journalDailyReminderLastSentDayKey);
    }

    // User profile / prefs on the parent doc (journal AI config/context).
    match /todo/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && !('journalDailyReminderLastSentDayKey' in request.resource.data)
        && request.resource.data.keys().hasOnly([
          'journalPersonalization',
          'journalImportantProfile',
          'journalAiCharacter',
          'journalRecentConversationHistory',
          'journalDailyReminderEnabled',
          'journalDailyReminderTimeZoneOffsetMinutes',
          'journalDailyReminderGreetingName',
          'taskCoins',
          'unlockedJournalAiCharacters',
        ])
        && (!('journalPersonalization' in request.resource.data)
            || (request.resource.data.journalPersonalization is string
                && request.resource.data.journalPersonalization.size() <= 10000))
        && (!('journalImportantProfile' in request.resource.data)
            || request.resource.data.journalImportantProfile is map)
        && (!('journalAiCharacter' in request.resource.data)
            || (request.resource.data.journalAiCharacter is string
                && validJournalAiCharacter(request.resource.data.journalAiCharacter)))
        && (!('journalRecentConversationHistory' in request.resource.data)
            || request.resource.data.journalRecentConversationHistory is list)
        && (!('journalDailyReminderEnabled' in request.resource.data)
            || request.resource.data.journalDailyReminderEnabled is bool)
        && (!('journalDailyReminderTimeZoneOffsetMinutes' in request.resource.data)
            || validJournalDailyReminderOffset(request.resource.data.journalDailyReminderTimeZoneOffsetMinutes))
        && (!('journalDailyReminderGreetingName' in request.resource.data)
            || (request.resource.data.journalDailyReminderGreetingName is string
                && request.resource.data.journalDailyReminderGreetingName.size() <= 40))
        && (!('taskCoins' in request.resource.data)
            || validTaskCoins(request.resource.data.taskCoins))
        && (!('unlockedJournalAiCharacters' in request.resource.data)
            || validUnlockedCharactersList(request.resource.data.unlockedJournalAiCharacters));
      allow update: if isOwner(userId)
        && journalReminderServerKeyOk()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'journalPersonalization',
          'journalImportantProfile',
          'journalAiCharacter',
          'journalRecentConversationHistory',
          'journalDailyReminderEnabled',
          'journalDailyReminderTimeZoneOffsetMinutes',
          'journalDailyReminderGreetingName',
          'taskCoins',
          'unlockedJournalAiCharacters',
        ])
        && (!('journalPersonalization' in request.resource.data)
            || (request.resource.data.journalPersonalization is string
                && request.resource.data.journalPersonalization.size() <= 10000))
        && (!('journalImportantProfile' in request.resource.data)
            || request.resource.data.journalImportantProfile is map)
        && (!('journalAiCharacter' in request.resource.data)
            || (request.resource.data.journalAiCharacter is string
                && validJournalAiCharacter(request.resource.data.journalAiCharacter)))
        && (!('journalRecentConversationHistory' in request.resource.data)
            || request.resource.data.journalRecentConversationHistory is list)
        && (!('journalDailyReminderEnabled' in request.resource.data)
            || request.resource.data.journalDailyReminderEnabled is bool)
        && (!('journalDailyReminderTimeZoneOffsetMinutes' in request.resource.data)
            || validJournalDailyReminderOffset(request.resource.data.journalDailyReminderTimeZoneOffsetMinutes))
        && (!('journalDailyReminderGreetingName' in request.resource.data)
            || (request.resource.data.journalDailyReminderGreetingName is string
                && request.resource.data.journalDailyReminderGreetingName.size() <= 40))
        && (!('taskCoins' in request.resource.data)
            || validTaskCoins(request.resource.data.taskCoins))
        && (!('unlockedJournalAiCharacters' in request.resource.data)
            || validUnlockedCharactersList(request.resource.data.unlockedJournalAiCharacters));
    }

    match /todo/{userId}/tasks/{taskId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && noServerReminderFieldsOnCreate();
      allow update: if isOwner(userId) && noServerReminderFieldsOnUpdate();
      allow delete: if isOwner(userId);
    }

    match /todo/{userId}/focus_tasks/{taskId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && noServerReminderFieldsOnCreate();
      allow update: if isOwner(userId) && noServerReminderFieldsOnUpdate();
      allow delete: if isOwner(userId);
    }

    match /todo/{userId}/deviceTokens/{tokenId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.token == tokenId
        && request.resource.data.updatedAt is timestamp;
      allow delete: if isOwner(userId);
    }

    match /todo/{userId}/mistakes/{mistakeId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /todo/{userId}/journal_entries/{entryId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /todo/{userId}/mistake_analyses/{analysisId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /dailyCheckSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Server-only queue for surprise journal AI (Cloud Functions).
    match /journal_ai_pending/{docId} {
      allow read, write: if false;
    }
  }
}
