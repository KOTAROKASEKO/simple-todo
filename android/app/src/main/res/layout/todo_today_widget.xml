<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_outer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_rounded"
    android:clipToOutline="true"
    android:padding="0dp">

    <LinearLayout
        android:id="@+id/widget_inner_panel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="#000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Today"
                android:textColor="#F9FAFB"
                android:textStyle="bold"
                android:textSize="18sp" />

            <Button
                android:id="@+id/widget_add_button"
                android:layout_width="70dp"
                android:layout_height="34dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_add_button_rounded"
                android:text="+ Add"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false" />

            <ImageButton
                android:id="@+id/widget_refresh_button"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_popup_sync"
                android:tint="#E5E7EB"
                android:contentDescription="Refresh" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_tasks_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="4dp">

            <TextView
                android:id="@+id/widget_empty_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No tasks for today"
                android:textColor="#D1D5DB"
                android:textSize="14sp"
                android:gravity="center_horizontal"
                android:paddingVertical="10dp" />

            <ListView
                android:id="@+id/widget_tasks_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp"
                android:scrollbars="vertical" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_updated_at"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=""
            android:textColor="#9CA3AF"
            android:textSize="11sp" />
    </LinearLayout>
</FrameLayout>
