# Firebase のキーを `service-account.json` で置けば .env 不要です。
# 置き場所: recipe-bulk-tool/ または リポジトリの親（simpletodo/）どちらでも自動検出（.gitignore は recipe-bulk-tool 側のみ）。
# それ以外なら .env.local を使い、**JSON 全文を FIREBASE_SERVICE_ACCOUNT_JSON に書かない**こと
# （private_key に「=」があり .env パーサと相性が悪いです）。

# 既定のオーナー UID（UI のデフォルト・公開参照）: 3DWpEWThrOUVwepIeBGIP2w9Vh32

# FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=   # cat service-account.json | base64 | tr -d '\n'
# RECIPE_IMPORT_SECRET=

# Pexels（サムネ取得）— 公式: Authorization に API キーをそのまま付与
# recipe-bulk-tool/.env.local に書く（リポジトリ直下の .env.local は dev で読まれないことがあります）
# PEXELS_API_KEY=   推奨（正しい綴り）。PXEL_API_KEY / PIXEL_API_KEY も可。
