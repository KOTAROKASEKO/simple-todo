{
  "name": "recipe-bulk-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('removed .next')}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "dev": "next dev -p 3456",
    "dev:fresh": "npm run clean && npm run dev",
    "build": "next build",
    "start": "next start -p 3456",
    "lint": "next lint"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
